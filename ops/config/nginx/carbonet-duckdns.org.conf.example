upstream carbonet_app {
    include /etc/nginx/carbonet/carbonet-main-upstream.inc;
    include /etc/nginx/carbonet/carbonet-idle-upstream.inc;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name carbonet.duckdns.org;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name carbonet.duckdns.org;

    ssl_certificate /etc/letsencrypt/live/carbonet.duckdns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/carbonet.duckdns.org/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:CarbonetSSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), geolocation=(), microphone=()" always;
    add_header Content-Security-Policy "upgrade-insecure-requests" always;

    proxy_http_version 1.1;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port 443;

    location = / {
        return 301 https://carbonet.duckdns.org/home;
    }

    location = /home {
        proxy_pass http://carbonet_app;
    }

    location / {
        proxy_pass http://carbonet_app;
    }
}
